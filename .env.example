# Required: Anthropic API key used by the agent and summarizer
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override default models
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_SUMMARIZER_MODEL=claude-haiku-4-5-20251001

# Optional: used by scheduler/daily.js
DAILY_TOPIC=latest developments in AI governance
# DAILY_PROMPT=Research this topic and produce a full report: "AI governance"
